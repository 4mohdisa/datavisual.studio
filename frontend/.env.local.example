# ---------------------------------------------------------------------------
# Auth (Clerk) — paste your keys from https://dashboard.clerk.com → API keys.
# While these are empty the app runs in OPEN mode (no sign-in required); the
# moment both are set, /studio, /chat, /dashboard and the API are locked and
# every user only sees their own data.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# The FastAPI engine (your AWS box in production). All user data lives on ITS
# local disk — there is no external database.
BACKEND_URL=http://localhost:8001

# Shared secret so only this Next server can reach the backend. Set the SAME
# value in the backend's .env (PROXY_SHARED_SECRET=...) when the backend is
# publicly reachable. Leave empty for local dev.
PROXY_SHARED_SECRET=

# Public URL of this site — used for SEO canonical URLs, the sitemap, robots
# and share-link absolute URLs. Defaults to https://datavisual.studio.
NEXT_PUBLIC_SITE_URL=https://datavisual.studio
