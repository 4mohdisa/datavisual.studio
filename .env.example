# Backend environment. In production, signed-in users bring their OWN AI keys
# (saved per-account from the app's "AI keys" panel) — the keys below are only
# the fallback for open dev mode (running without Clerk).
OPENROUTER_API_KEY=sk-or-v1-...
# Optional: direct Google Gemini API key — Gemini models bypass OpenRouter
# (cheaper; flash tier is nearly free). Get one at https://aistudio.google.com
GEMINI_API_KEY=
# Optional: enable verbose debug logging
DATAVISUAL_DEBUG=false

# --- Production settings ---
# Shared secret required on every /api request when set — only your Next.js
# proxy (same value in its .env.local) can reach the API. REQUIRED in prod.
PROXY_SHARED_SECRET=
# Fernet key that encrypts users' stored API keys at rest. REQUIRED in prod
# (the backend refuses to boot if PROXY_SHARED_SECRET is set and this isn't).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# It MUST travel with data/ — a fresh key against a restored data/ makes every
# stored key unreadable.
SECRET_KEY=
# Path to Chromium/Chrome for chart rendering + PDF export (Docker sets this to
# /usr/bin/chromium). Leave blank to auto-discover a local install.
BROWSER_PATH=
# Password for /admin (users + project analytics). No account needed —
# entering this password on the admin page is the only gate.
ADMIN_PASSWORD=
# Your deployed frontend URL, added to CORS allowed origins.
FRONTEND_ORIGIN=https://datavisual.studio
